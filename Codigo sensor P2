#include <WiFi.h>

const char* ssid = "TU_WIFI";
const char* password = "TU_PASSWORD";

const char* serverIP = "192.168.100.8";
const int serverPort = 5000;

WiFiClient client;

int trigPin = 5;
int echoPin = 18;

long duration;
float distance;

void conectarWiFi() {
  WiFi.begin(ssid, password);
  Serial.print("Conectando WiFi");

  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println("\n✅ Conectado");
  Serial.println(WiFi.localIP());
}

float medirDistancia() {
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);

  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  duration = pulseIn(echoPin, HIGH, 30000); // timeout
  return duration * 0.034 / 2;
}

void setup() {
  Serial.begin(115200);

  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);

  conectarWiFi();
}

void loop() {
  if (WiFi.status() != WL_CONNECTED) {
    conectarWiFi();
  }

  distance = medirDistancia();

  Serial.print("📏 Distancia: ");
  Serial.println(distance);

  if (client.connect(serverIP, serverPort)) {
    String json = "{\"distance\":" + String(distance) + "}";
    client.print(json);
    client.stop();
    Serial.println("📤 Enviado al server");
  } else {
    Serial.println("❌ Error conectando al server");
  }

  delay(2000);
}
