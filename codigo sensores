class Led {
  private:
    int pin;

  public:
    Led(int p) {
      pin = p;
    }

    void init() {
      pinMode(pin, OUTPUT);
    }

    void turnOn() {
      digitalWrite(pin, HIGH);
    }

    void turnOff() {
      digitalWrite(pin, LOW);
    }
};

class UltrasonicSensor {
  private:
    int trigPin;
    int echoPin;

  public:
    UltrasonicSensor(int trig, int echo) {
      trigPin = trig;
      echoPin = echo;
    }

    void init() {
      pinMode(trigPin, OUTPUT);
      pinMode(echoPin, INPUT);
    }

    float getDistance() {

      digitalWrite(trigPin, LOW);
      delayMicroseconds(2);

      digitalWrite(trigPin, HIGH);
      delayMicroseconds(10);
      digitalWrite(trigPin, LOW);

      long duration = pulseIn(echoPin, HIGH);

      float distance = duration * 0.034 / 2;

      return distance;
    }
};

class LedController {
  private:
    Led &led1;
    Led &led2;
    Led &led3;

  public:
    LedController(Led &l1, Led &l2, Led &l3) : led1(l1), led2(l2), led3(l3) {}

    void update(float distance) {

      if (distance > 30) {
        led1.turnOn();
        led2.turnOff();
        led3.turnOff();
      }

      else if (distance > 15) {
        led1.turnOff();
        led2.turnOn();
        led3.turnOff();
      }

      else {
        led1.turnOff();
        led2.turnOff();
        led3.turnOn();
      }
    }
};

Led led1(5);
Led led2(4);
Led led3(12);

UltrasonicSensor sensor(18,35);

LedController controller(led1, led2, led3);

float previousDistance = 0;

void setup() {

  led1.init();
  led2.init();
  led3.init();

  sensor.init();

  Serial.begin(9600);
}

void loop() {

  float sum = 0;
  int samples = 5;

  for(int i = 0; i < samples; i++){
    sum += sensor.getDistance();
    delay(20);
  }

  float distance = sum / samples;

  // MINIMUM CHANGE FILTER
  if(abs(distance - previousDistance) > 3){
    previousDistance = distance;
  }

  Serial.print("Distance: ");
  Serial.print(previousDistance);
  Serial.println(" cm");

  controller.update(previousDistance);

  delay(200);
}
